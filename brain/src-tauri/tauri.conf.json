{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoReji",
  "version": "1.1.0",
  "identifier": "com.autoreji.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AutoReji beta v1.1",
        "width": 1280,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "public.app-category.video",
    "publisher": "Madyes",
    "copyright": "AutoReji beta v1.1 · Developed by Madyes © 2026",
    "licenseFile": "../../LICENSE",
    "externalBin": ["binaries/autoreji-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    }
  }
}
